# pyenv
#   For a library or package, you might want to share your .python-version.
#   Template serialization: https://github.com/github/gitignore/blob/main/Global/Python.gitignore
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different python versions,
#   Pipfile.lock might cause friction.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock
#   Pedantic dependency specification: https://python-poetry.org/docs/dependency-specification/

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#   pdm.lock
#   pdm configuration file
.pdm.toml
.pdm-plugins/

